# ── Datastores ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aduana:aduana@localhost:5432/aduanamap
REDIS_URL=redis://localhost:6379/0

# ── Object storage (snapshots crudos) ──────────────────────────────────────
OBJECT_STORAGE_BUCKET=aduanamap-snapshots
OBJECT_STORAGE_KEY=
OBJECT_STORAGE_SECRET=
OBJECT_STORAGE_ENDPOINT=http://localhost:9000

# ── Banxico SIE ────────────────────────────────────────────────────────────
# El token oficial tiene 64 caracteres. La API recomienda CACHEAR respuestas.
# Límites: consultas oportunas 80/min y 40,000/día; históricas 200/5min y 10,000/día.
BANXICO_TOKEN=
BANXICO_FIX_SERIE=SF43718

# ── Núcleo ETL existente (comercio-exterior-mexico) ────────────────────────
# Se encapsula, no se reescribe. Los workers invocan su CLI y migran su
# warehouse DuckDB curado a PostgreSQL. Ver docs/architecture/etl-core.md
COMEX_REPO_PATH=C:\Users\jcgam\Downloads\Trabajo\pruebas\comercio-exterior-mexico
COMEX_DUCKDB_PATH=

# ── Fuentes ETL (capture stage). Sin URL, el worker corre en DRY-RUN. ───────
# Verifica cada URL contra un snapshot real antes de escribir el parser.
SNICE_LIGIE_URL=
VUCEM_CLASIFICADOR_URL=
ANAM_TRATADOS_URL=
DOF_COMEX_URL=

# ── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
APP_ENV=development
# Rate limiting público (429 + Retry-After). Poner 0 solo en pruebas.
RATE_LIMIT_ENABLED=1
NEXT_PUBLIC_SITE_NAME=AduanaMap MX
# Origen público: canonical URLs, hreflang, sitemap.xml y tarjetas OG.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Basemap del mapa. Vacío = estilo autocontenido (océano + países), sin tile server.
# Opcional: URL de estilo MapLibre (p.ej. un PMTiles propio) — ver ADR 0004.
NEXT_PUBLIC_MAP_STYLE_URL=

# ── Observabilidad ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
