# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / Next.js
node_modules/
.next/
out/
dist/
*.tsbuildinfo
next-env.d.ts

# Env & secrets
.env
.env.*
!.env.example

# Data (raw snapshots are large / reproducible — keep out of git)
data/raw/*
data/snapshots/*
data/processed/*
!data/**/.gitkeep
# Generated geometry: the runtime copy lives in apps/web/public/geo (tracked);
# this data/geojson copy is the regenerable ETL-input mirror.
data/geojson/*.geojson

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Logs
*.log
